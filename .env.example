APP_ENV=LOCAL
DATABASE_URL=postgresql://postgres@localhost:5432/apautomation
AP_DASHBOARD_DSN=postgresql://postgres@localhost:5432/apautomation

AZURE_OPENAI_ENDPOINT=https://example-openai.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=deployment-name
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_AUTH_MODE=identity

AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://example-document-intelligence.cognitiveservices.azure.com
AZURE_DOCUMENT_INTELLIGENCE_AUTH_MODE=identity

GRAPH_AUTH_MODE=client_secret
AZURE-TENANT-ID=00000000-0000-0000-0000-000000000000
AZURE-CLIENT-ID-MAIL=00000000-0000-0000-0000-000000000000
AZURE-CLIENT-SECRET-MAIL=<local-only-client-secret>
USER-PRINCIPAL-NAME-MAIL=ap-intake@example.com

TEAMS-WEBHOOK-URL-PROPERTIES-AP=<key-vault-or-local-only-webhook-url>
